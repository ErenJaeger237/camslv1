# Python
__pycache__/
*.py[cod]
*.pyo

# Virtual environment — hundreds of MB, never commit
venv/
env/
.venv/

# Large dataset files — too big for GitHub (70 MB+)
data/raw/
data/features.csv
data/signs/
data/learning.db

# Trained model weights — regenerated by train.py / train_signs.py
models/alphabet.keras
models/signs.keras
# signs.onnx and signs_labels.json ARE committed (303 KB, used by Render)

# MediaPipe task bundles — downloaded by src/download_models.py
models/hand_landmarker.task
models/face_landmarker.task
models/pose_landmarker_lite.task

# Generated outputs — plots rebuilt by train.py
outputs/confusion_matrix.png
outputs/accuracy_curves.png
outputs/signs_confusion.png
outputs/signs_training_curves.png
# Keep results.txt — dissertation Chapter 4 numbers
!outputs/results.txt

# Secrets / local config
.env
*.key
.kaggle/

# Scratch / experimental work
scratch/

# Frontend build artifacts
frontend/node_modules/
frontend/dist/
frontend/.env.local

# Backend per-session data
backend/data/

# TF.js model files — alphabet model committed so Vercel can serve it
# signs model excluded (large, not yet production-ready)
frontend/public/models/signs/

# MediaPipe WASM (copied from node_modules by npm postinstall)
frontend/public/mediapipe/

